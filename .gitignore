```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Environment variables
.env
.env.local
*.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db
```